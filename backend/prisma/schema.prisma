// ─── Marketing Campaigns ──────────────────────────────────────────────────────

model MarketingCampaign {
  id             String    @id @default(uuid())
  gymId          String
  createdById    String
  name           String
  subject        String?
  body           String
  imageUrl       String?
  channels       String[]  @default(["PUSH", "IN_APP"])
  targetAudience String // ALL | ACTIVE | EXPIRED | PENDING | INACTIVE_30D | INACTIVE_60D
  targetPlanId   String?
  status         String    @default("DRAFT") // DRAFT | SENDING | SENT | FAILED
  scheduledAt    DateTime?
  sentAt         DateTime?
  totalTargeted  Int       @default(0)
  totalDelivered Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  gym            Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  createdBy      User      @relation("CampaignCreator", fields: [createdById], references: [id])

  @@index([gymId, status])
  @@map("marketing_campaigns")
}

// ─── Automation Rules ──────────────────────────────────────────────────────────

model AutomationRule {
  id         String    @id @default(uuid())
  gymId      String
  name       String
  trigger    String // INACTIVE_14D | INACTIVE_30D | EXPIRY_5D | EXPIRY_1D | JUST_EXPIRED | NEW_MEMBER_DAY1 | NEW_MEMBER_DAY3 | NEW_MEMBER_DAY7
  subject    String?
  body       String
  channels   String[]  @default(["PUSH", "IN_APP"])
  isActive   Boolean   @default(true)
  lastRunAt  DateTime?
  totalFired Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  gym        Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, isActive])
  @@map("automation_rules")
}

// ─── Gym Announcements ────────────────────────────────────────────────────────

model GymAnnouncement {
  id             String   @id @default(uuid())
  gymId          String
  authorId       String
  title          String
  body           String
  imageUrl       String?
  isPinned       Boolean  @default(false)
  targetAudience String   @default("ALL") // ALL | ACTIVE | EXPIRED | PENDING
  channels       String[] @default(["PUSH", "IN_APP"])
  totalDelivered Int      @default(0)
  publishedAt    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  gym            Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  author         User     @relation("AnnouncementAuthor", fields: [authorId], references: [id])

  @@index([gymId, publishedAt(sort: Desc)])
  @@map("gym_announcements")
}

// ─── Training Sessions & Bookings ────────────────────────────────────────────

model TrainingSession {
  id          String           @id @default(uuid())
  gymId       String
  trainerId   String
  title       String
  description String?
  type        String           @default("GROUP_CLASS") // GROUP_CLASS | ONE_ON_ONE | WORKSHOP
  startTime   DateTime
  endTime     DateTime
  maxCapacity Int              @default(20)
  location    String?
  status      String           @default("SCHEDULED") // SCHEDULED | CANCELLED | COMPLETED
  color       String? // hex color for calendar display
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  gym         Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  trainer     TrainerProfile   @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  bookings    SessionBooking[]

  @@index([gymId, startTime])
  @@index([trainerId, startTime])
  @@map("training_sessions")
}

model SessionBooking {
  id        String          @id @default(uuid())
  sessionId String
  userId    String
  status    String          @default("CONFIRMED") // CONFIRMED | CANCELLED | ATTENDED | NO_SHOW
  bookedAt  DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  session   TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@index([userId, status])
  @@map("session_bookings")
}

// ─── Support Tickets ──────────────────────────────────────────────────────────

model SupportTicket {
  id         String          @id @default(uuid())
  gymId      String
  userId     String
  subject    String
  status     String          @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  priority   String          @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  ticketType String          @default("SUPPORT") // SUPPORT | TRAINER_CONVERSATION
  trainerId  String? // populated for TRAINER_CONVERSATION tickets
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  gym        Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user       User            @relation("TicketOwner", fields: [userId], references: [id], onDelete: Cascade)
  trainer    TrainerProfile? @relation("TrainerConversations", fields: [trainerId], references: [id])
  messages   TicketMessage[]

  @@index([gymId, status])
  @@index([gymId, ticketType])
  @@index([trainerId])
  @@index([userId])
  @@map("support_tickets")
}

// ─── Trainer Assignment Requests ──────────────────────────────────────────────

model TrainerAssignmentRequest {
  id        String         @id @default(uuid())
  gymId     String
  memberId  String
  trainerId String
  status    String         @default("PENDING") // PENDING | APPROVED | REJECTED
  message   String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  gym       Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member    User           @relation("MemberTrainerRequests", fields: [memberId], references: [id], onDelete: Cascade)
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([memberId, gymId, status])
  @@index([trainerId, status])
  @@index([gymId])
  @@map("trainer_assignment_requests")
}

model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  senderId  String
  body      String
  isStaff   Boolean       @default(false)
  readAt    DateTime?
  createdAt DateTime      @default(now())
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User          @relation("TicketMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@map("ticket_messages")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  gymId     String
  actorId   String
  action    String // e.g. MEMBERSHIP_FROZEN, SESSION_CANCELLED, TICKET_RESOLVED
  entity    String // e.g. membership, session, ticket, trainer, plan
  entityId  String?
  label     String // human-readable description shown in UI
  metadata  Json? // optional extra context (old/new values, etc.)
  createdAt DateTime @default(now())

  gym   Gym  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  actor User @relation("AuditActor", fields: [actorId], references: [id])

  @@index([gymId, createdAt(sort: Desc)])
  @@index([actorId])
  @@map("audit_logs")
}

// ─── Webhooks ─────────────────────────────────────────────────────────────────

model WebhookEndpoint {
  id        String   @id @default(uuid())
  gymId     String
  url       String
  secret    String   @default(cuid())
  events    String[] // e.g. ["member.created", "payment.received"]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gym        Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([gymId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id           String   @id @default(uuid())
  endpointId   String
  event        String
  payload      Json
  statusCode   Int?
  responseBody String?
  success      Boolean  @default(false)
  duration     Int? // ms
  attemptedAt  DateTime @default(now())

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, attemptedAt(sort: Desc)])
  @@map("webhook_deliveries")
}

// Idempotency table — prevents Stripe events from being processed twice on retries.
// Cleanup cron should delete rows older than 7 days.
model ProcessedWebhookEvent {
  id             String   @id @default(uuid())
  stripeEventId  String   @unique // Stripe event id e.g. evt_1234abc
  eventType      String   // e.g. "payment_intent.succeeded"
  processedAt    DateTime @default(now())

  @@index([processedAt(sort: Desc)])
  @@map("processed_webhook_events")
}


// ─── Progress Rooms ───────────────────────────────────────────────────────────

model ProgressRoom {
  id          String    @id @default(uuid())
  gymId       String
  creatorId   String
  name        String
  description String?
  metric      String // CHECKINS | SESSIONS | STREAK
  period      String // WEEKLY | MONTHLY | ONGOING | CUSTOM
  startDate   DateTime  @default(now())
  endDate     DateTime? // null = ongoing/rolling
  isPublic    Boolean   @default(true)
  inviteCode  String    @unique
  maxMembers  Int       @default(30)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  gym     Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  creator User             @relation("RoomCreator", fields: [creatorId], references: [id])
  members RoomMembership[]

  @@index([gymId, isActive])
  @@map("progress_rooms")
}

model RoomMembership {
  id           String   @id @default(uuid())
  roomId       String
  userId       String
  joinedAt     DateTime @default(now())
  totalPoints  Int      @default(0)
  weeklyPoints Int      @default(0) // reset every Monday midnight

  room        ProgressRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pointEvents PointEvent[]

  @@unique([roomId, userId])
  @@index([roomId, totalPoints(sort: Desc)])
  @@index([userId])
  @@map("room_memberships")
}

// ─── Point Events (leaderboard audit trail) ───────────────────────────────────

model PointEvent {
  id           String          @id @default(uuid())
  userId       String
  roomId       String
  membershipId String // RoomMembership.id
  sourceId     String // workoutHistoryId | challengeId | attendanceId
  sourceType   PointSourceType
  delta        Int // positive = award, negative = penalty
  reason       String
  createdAt    DateTime        @default(now())

  membership RoomMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@index([userId, roomId])
  @@index([roomId, createdAt(sort: Desc)])
  @@map("point_events")
}

// ─── Exercise Library ─────────────────────────────────────────────────────────

model ExerciseLibrary {
  id               String            @id @default(uuid())
  name             String            @unique
  nameKa           String?
  nameRu           String?
  primaryMuscle    String
  secondaryMuscles String[]
  equipment        String[]
  difficulty       DifficultyLevel   @default(BEGINNER)
  mechanics        ExerciseMechanics @default(COMPOUND)
  force            ExerciseForce     @default(PUSH)
  videoUrl         String?
  cues             String[]
  commonMistakes   String[]
  metValue         Float             @default(3.0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())

  exerciseSets      ExerciseSet[]
  completedSets     CompletedSet[]
  MasterExerciseSet MasterExerciseSet[]

  @@index([primaryMuscle])
  @@index([mechanics])
  @@map("exercise_library")
}

// ─── Food Database ────────────────────────────────────────────────────────────

model FoodItem {
  id           String        @id @default(uuid())
  name         String
  nameKa       String?
  nameRu       String?
  brand        String?
  barcode      String?       @unique
  calories     Float // per 100g
  protein      Float
  carbs        Float
  fats         Float
  fiber        Float?
  sugar        Float?
  sodium       Float?
  foodCategory FoodCategory?
  source       FoodSource    @default(USER)
  isVerified   Boolean       @default(false)
  createdBy    String? // trainerUserId when source = TRAINER
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  foodLogs FoodLog[]

  @@index([name])
  @@index([barcode])
  @@index([source, isVerified])
  @@index([createdBy])
  @@map("food_items")
}

model FoodLog {
  id              String   @id @default(uuid())
  userId          String
  dailyProgressId String?
  foodItemId      String
  mealType        MealType
  grams           Float
  calories        Float // denormalized: (grams/100) × foodItem.calories
  protein         Float
  carbs           Float
  fats            Float
  fiber           Float?
  loggedAt        DateTime @default(now())
  /// Client-generated idempotency key. Deduplicates retried food-log requests per user.
  idempotencyKey  String?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItem      FoodItem       @relation(fields: [foodItemId], references: [id])
  dailyProgress DailyProgress? @relation(fields: [dailyProgressId], references: [id])

  @@unique([userId, idempotencyKey], name: "foodLog_userIdempotency")
  @@index([userId, loggedAt(sort: Desc)])
  @@index([dailyProgressId])
  @@map("food_logs")
}

// Tracks which meals a user has marked as consumed on a given date.
// refId holds Meal.id for literal meals or MasterMeal.id for AI/template meals.
// The unique constraint prevents double-logging the same meal on the same date.
model MealLog {
  id       String   @id @default(uuid())
  userId   String
  refId    String
  date     DateTime @db.Date
  loggedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, refId, date])
  @@index([userId, date])
  @@map("meal_logs")
}

// ─── QR Nonce (replay attack prevention) ─────────────────────────────────────

model QrNonce {
  nonce     String    @id // the UUID nonce from the QR payload
  gymId     String
  type      QrType
  usedAt    DateTime?
  usedBy    String? // userId who consumed it
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([expiresAt]) // for cleanup cron
  @@index([gymId])
  @@map("qr_nonces")
}

// ─── Daily Recovery (wearable data) ──────────────────────────────────────────

model DailyRecovery {
  id            String         @id @default(uuid())
  userId        String
  date          DateTime       @db.Date
  hrv           Float? // heart rate variability (ms)
  restingHR     Int? // resting heart rate (bpm)
  sleepHours    Float?
  sleepQuality  Int? // 1–10 self-reported or AI-scored
  recoveryScore Int            @default(0) // 0–100 computed
  source        RecoverySource @default(MANUAL)
  rawData       Json? // raw payload from HealthKit / Health Connect
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date(sort: Desc)])
  @@map("daily_recoveries")
}

// ─── Gym Zones (occupancy heat-map) ──────────────────────────────────────────

model GymZone {
  id         String   @id @default(uuid())
  gymId      String
  name       String // "Free Weights", "Cardio", "Pool", "Studio"
  capacity   Int      @default(20)
  isActive   Boolean  @default(true)
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  gym         Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@unique([gymId, name])
  @@index([gymId, isActive])
  @@map("gym_zones")
}

// ─── NEW CORE ENTITIES ────────────────────────────────────────────────────────

model Branch {
  id        String   @id @default(uuid())
  name      String
  address   String?
  gymId     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  admins    User[]   @relation("BranchAdmins")

  @@map("branches")
}

model UserWeightHistory {
  id        String   @id @default(uuid())
  userId    String
  weight    Decimal  @db.Decimal(10, 2)
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date(sort: Desc)])
  @@map("user_weight_history")
}

model WorkoutPlanVersion {
  id            String      @id @default(uuid())
  workoutPlanId String
  version       Int
  data          Json
  createdAt     DateTime    @default(now())
  workoutPlan   WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@unique([workoutPlanId, version])
  @@map("workout_plan_versions")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model UserDevice {
  id           String    @id @default(uuid())
  userId       String
  fcmToken     String    @unique
  platform     String?   // "ios" | "android"
  deviceName   String?
  lastActiveAt DateTime  @default(now())
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_devices")
}

