// Protocol the hardware gateway uses to communicate with door hardware
enum GatewayProtocol {
  RELAY_HTTP // Simple HTTP webhook → triggers relay (most universal)
  WIEGAND // Output Wiegand 26/34 signal to access controller
  OSDP_V2 // Open Supervised Device Protocol v2 (RS-485, encrypted)
  ZKTECO_TCP // ZKTeco proprietary TCP/IP protocol
  SALTO_OSDP // Salto Systems via OSDP
  MQTT // MQTT broker (IoT-style, ESP32/industrial panels)
}

// Command types the backend can push to a gateway
enum GatewayCmd {
  UNLOCK // Open door for N milliseconds
  LOCK // Force lock (emergency)
  STATUS // Request health/status report
  ALARM // Trigger alarm relay
}

enum CommandStatus {
  PENDING // Created, not yet sent
  SENT // Delivered to gateway (WebSocket push)
  EXECUTED // Gateway confirmed relay triggered
  FAILED // Gateway reported error
  EXPIRED // Not picked up before expiresAt
}

// Physical or virtual credential type
enum CardType {
  RFID_125KHZ // EM4100, HID Prox — 125kHz (most common legacy fobs)
  NFC_MIFARE // Mifare Classic/Plus — 13.56MHz (most common modern cards)
  NFC_DESFIRE // Mifare DESFire EV2/EV3 — encrypted, highest security
  PHONE_HCE // Android Host Card Emulation or iOS CoreNFC
  WIEGAND_RAW // Raw Wiegand facility+card number (no UID)
}

