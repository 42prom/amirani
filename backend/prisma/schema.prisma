model WorkoutHistory {
  id              String          @id @default(uuid())
  completedAt     DateTime        @default(now())
  durationMinutes Int
  caloriesBurned  Decimal?        @db.Decimal(10, 2)
  totalVolume     Decimal?        @db.Decimal(10, 2)
  notes           String?
  /// Client-generated key used to deduplicate retried sync requests.
  /// If two requests arrive with the same key for the same user, the second is ignored.
  idempotencyKey  String?
  userId          String
  routineId       String?
  completedSets   CompletedSet[]
  routine         WorkoutRoutine? @relation(fields: [routineId], references: [id])
  user            User            @relation("UserWorkoutHistory", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, idempotencyKey], name: "workoutHistory_userIdempotency")
  @@index([userId, completedAt(sort: Desc)])
  @@index([routineId])
