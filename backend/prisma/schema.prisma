generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String                     @id @default(uuid())
  email                    String                     @unique
  password                 String
  fullName                 String
  role                     Role                       @default(HOME_USER)
  timezone                 String?                    @default("UTC")
  phoneNumber              String?
  avatarUrl                String?
  isVerified               Boolean                    @default(false)
  isActive                 Boolean                    @default(true)
  mustChangePassword       Boolean                    @default(false)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  stripeCustomerId         String?                    @unique
  createdById              String?
  managedGymId             String?
  saasNextBillingDate      DateTime?
  saasSubscriptionStatus   SaaSSubscriptionStatus     @default(OFF)
  saasTrialEndsAt          DateTime?
  address                  String?
  dob                      String?
  firstName                String?
  gender                   Gender?
  fitnessLevel             FitnessLevel?
  fitnessGoal              FitnessGoal?
  deletedAt                DateTime?
  height                   String?
  idPhotoUrl               String?
  lastName                 String?
  medicalConditions        String?
  noMedicalConditions      Boolean                    @default(false)
  personalNumber           String?
  weight                   Decimal?                   @db.Decimal(10, 2)
  heightCm                 Float?
  targetWeightKg           Decimal?                   @db.Decimal(10, 2)
  unitPreference           UnitSystem                 @default(METRIC)
  languagePreference       LanguagePreference         @default(EN)
  customPlatformFeePercent Float?
  customPricePerBranch     Float?
  isLifetimeFree           Boolean                    @default(false)
  totalPoints              Int                        @default(0)
  streakDays               Int                        @default(0)
  lastActivityAt           DateTime?                  @db.Date
  activeGymId              String?
  activeGym                Gym?                       @relation("ActiveGym", fields: [activeGymId], references: [id])
  attendances              Attendance[]
  dailyProgress            DailyProgress[]            @relation("UserDailyProgress")
  approvedDeposits         Deposit[]                  @relation("ApprovedDeposits")
  submittedDeposits        Deposit[]                  @relation("SubmittedDeposits")
  dietPlans                DietPlan[]
  doorAccessLogs           DoorAccessLog[]
  cardCredentials          CardCredential[]
  memberships              GymMembership[]
  ownedGyms                Gym[]                      @relation("GymOwner")
  notificationPreference   NotificationPreference?
  notifications            Notification[]
  payments                 Payment[]
  trainerProfile           TrainerProfile?
  challenges               UserChallenge[]            @relation("UserChallenges")
  weightHistory            UserWeightHistory[]
  refreshTokens            RefreshToken[]
  devices                  UserDevice[]
  branchAdminOf            Branch[]                   @relation("BranchAdmins")
  createdBy                User?                      @relation("CreatedByUser", fields: [createdById], references: [id])
  createdUsers             User[]                     @relation("CreatedByUser")
  managedGym               Gym?                       @relation("BranchAdmin", fields: [managedGymId], references: [id])
  workoutHistory           WorkoutHistory[]           @relation("UserWorkoutHistory")
  workoutPlans             WorkoutPlan[]
  createdCampaigns         MarketingCampaign[]        @relation("CampaignCreator")
  announcements            GymAnnouncement[]          @relation("AnnouncementAuthor")
  sessionBookings          SessionBooking[]
  supportTickets           SupportTicket[]            @relation("TicketOwner")
  ticketMessages           TicketMessage[]            @relation("TicketMessageSender")
  trainerRequests          TrainerAssignmentRequest[] @relation("MemberTrainerRequests")
  auditLogs                AuditLog[]                 @relation("AuditActor")
  createdRooms             ProgressRoom[]             @relation("RoomCreator")
  roomMemberships          RoomMembership[]
  dailyRecoveries          DailyRecovery[]
  foodLogs                 FoodLog[]
  mealLogs                 MealLog[]

  @@map("users")
}

model Invitation {
  id             String           @id @default(uuid())
  email          String
  inviteToken    String           @unique @default(uuid())
  status         InvitationStatus @default(PENDING)
  expiresAt      DateTime
  createdAt      DateTime         @default(now())
  acceptedAt     DateTime?
  invitedById    String
  acceptedUserId String?

  @@index([email])
  @@index([inviteToken])
  @@map("invitations")
}

model Gym {
  id                       String                     @id @default(uuid())
  name                     String
  address                  String
  city                     String
  country                  String
  phone                    String?
  email                    String?
  logoUrl                  String?
  description              String?
  isActive                 Boolean                    @default(true)
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  ownerId                  String
  stripeAccountId          String?                    @unique
  stripeAccountStatus      String?
  stripeOnboardingComplete Boolean                    @default(false)
  stripePayoutsEnabled     Boolean                    @default(false)
  stripeCurrency           String                     @default("usd")
  registrationRequirements Json?
  registrationCode         String?                    @unique
  bannerUrl                String?
  themeColor               String? // hex e.g. #F1C40F
  welcomeMessage           String? // shown to members in mobile app
  qrSecret                 String? // HMAC secret for QR signing (auto-generated on gym create)
  attendances              Attendance[]
  deposits                 Deposit[]                  @relation("GymDeposits")
  doorSystems              DoorSystem[]
  hardwareGateways         HardwareGateway[]
  cardCredentials          CardCredential[]
  equipment                Equipment[]
  memberships              GymMembership[]
  owner                    User                       @relation("GymOwner", fields: [ownerId], references: [id])
  subscriptionPlans        SubscriptionPlan[]
  trainers                 TrainerProfile[]
  branchAdmins             User[]                     @relation("BranchAdmin")
  campaigns                MarketingCampaign[]
  automationRules          AutomationRule[]
  announcements            GymAnnouncement[]
  trainingSessions         TrainingSession[]
  supportTickets           SupportTicket[]
  auditLogs                AuditLog[]
  webhookEndpoints         WebhookEndpoint[]
  progressRooms            ProgressRoom[]
  zones                    GymZone[]
  activeMembers            User[]                     @relation("ActiveGym")
  assignmentRequests       TrainerAssignmentRequest[]
  branches                 Branch[]
  deletedAt                DateTime?

  @@map("gyms")
}

model TrainerProfile {
  id                   String                     @id @default(uuid())
  specialization       String?
  bio                  String?
  certifications       String[]
  isAvailable          Boolean                    @default(true)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime                   @updatedAt
  userId               String?                    @unique
  gymId                String
  age                  Int?
  avatarUrl            String?
  fullName             String
  assignedMembers      GymMembership[]
  gym                  Gym                        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user                 User?                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedPlans        WorkoutPlan[]
  assignedDietPlans    DietPlan[]
  trainingSessions     TrainingSession[]
  draftTemplates       TrainerDraftTemplate[]
  assignmentRequests   TrainerAssignmentRequest[]
  supportConversations SupportTicket[]            @relation("TrainerConversations")

  @@map("trainer_profiles")
}

model TrainerDraftTemplate {
  id        String         @id @default(uuid())
  trainerId String
  type      String // "meal" | "day" | "week"
  name      String
  data      Json
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  trainer   TrainerProfile @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@map("trainer_draft_templates")
}

model SubscriptionPlan {
  id                 String          @id @default(uuid())
  name               String
  description        String?
  features           String[]
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  hasTimeRestriction Boolean         @default(false)
  accessStartTime    String?
  accessEndTime      String?
  accessDays         DayOfWeek[]     @default([MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY, SATURDAY, SUNDAY])
  planType           String          @default("full")
  displayOrder       Int             @default(0)
  gymId              String
  durationUnit       String          @default("days")
  durationValue      Int             @default(30)
  price              Decimal?        @db.Decimal(10, 2)
  memberships        GymMembership[]
  gym                Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@map("subscription_plans")
}

model GymMembership {
  id           String             @id @default(uuid())
  startDate    DateTime           @default(now())
  endDate      DateTime
  status       SubscriptionStatus @default(PENDING)
  stripeSubId  String?
  autoRenew    Boolean            @default(false)
  frozenAt     DateTime?
  frozenUntil  DateTime?
  freezeReason String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?
  userId       String
  gymId        String
  planId       String
  trainerId    String?
  gym          Gym                @relation(fields: [gymId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan   @relation(fields: [planId], references: [id])
  trainer      TrainerProfile?    @relation(fields: [trainerId], references: [id])
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gymId])
  @@index([userId, gymId, status])
  @@index([gymId, status])
  @@map("gym_memberships")
}

model EquipmentCatalog {
  id             String            @id @default(uuid())
  name           String
  category       EquipmentCategory @default(OTHER)
  brand          String?
  model          String?
  description    String?
  imageUrl       String?
  images         String[]
  specifications Json?
  msrpPrice      Decimal?          @db.Decimal(10, 2)
  manufacturer   String?
  tags           String[]
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  gymEquipment   Equipment[]

  @@index([category])
  @@index([brand])
  @@map("equipment_catalog")
}

model Equipment {
  id                  String            @id @default(uuid())
  name                String
  category            EquipmentCategory @default(OTHER)
  brand               String?
  quantity            Int               @default(1)
  status              EquipmentStatus   @default(AVAILABLE)
  purchaseDate        DateTime?
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  description         String?
  imageUrl            String?
  serialNumber        String?
  purchasePrice       Decimal?          @db.Decimal(10, 2)
  warrantyExpiry      DateTime?
  location            String?
  catalogItemId       String?
  gymId               String
  model               String?
  catalogItem         EquipmentCatalog? @relation(fields: [catalogItemId], references: [id])
  gym                 Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, category])
  @@index([gymId, status])
  @@index([catalogItemId])
  @@map("equipment")
}

model DoorSystem {
  id           String          @id @default(uuid())
  name         String
  type         DoorSystemType
  location     String?
  vendorConfig Json?
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  gymId        String
  accessLogs   DoorAccessLog[]
  gym          Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@map("door_systems")
}

model DoorAccessLog {
  id            String         @id @default(uuid())
  accessTime    DateTime       @default(now())
  accessGranted Boolean
  method        DoorSystemType
  deviceInfo    String?
  doorSystemId  String
  userId        String
  doorSystem    DoorSystem     @relation(fields: [doorSystemId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("door_access_logs")
}

// ─── Hardware Gateway ────────────────────────────────────────────────────────
// A local controller (Raspberry Pi, ESP32, ZKTeco panel, etc.) that bridges
// cloud commands to physical door hardware (relay, Wiegand reader, OSDP).

model HardwareGateway {
  id         String           @id @default(uuid())
  name       String
  gymId      String
  apiKey     String           @unique @default(uuid())
  location   String?
  protocol   GatewayProtocol  @default(RELAY_HTTP)
  config     Json? // vendor-specific: { ip, port, relayPin, wiegandBits, ... }
  isOnline   Boolean          @default(false)
  lastSeenAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  gym        Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  commands   GatewayCommand[]

  @@map("hardware_gateways")
}

// Command queue: backend pushes commands, gateway polls or receives via WebSocket
model GatewayCommand {
  id          String          @id @default(uuid())
  gatewayId   String
  doorId      String? // optional: target specific door/relay on the gateway
  command     GatewayCmd
  payload     Json? // e.g. { durationMs: 3000, wiegandCode: "0A1B2C" }
  status      CommandStatus   @default(PENDING)
  triggeredBy String? // userId who triggered (null = system)
  createdAt   DateTime        @default(now())
  expiresAt   DateTime // command auto-expires if not picked up
  executedAt  DateTime?
  gateway     HardwareGateway @relation(fields: [gatewayId], references: [id], onDelete: Cascade)

  @@index([gatewayId, status])
  @@map("gateway_commands")
}

// Physical card / credential bound to a user at a gym.
// Covers: RFID fob, NFC card (Mifare/DESFire), phone HCE virtual card.
model CardCredential {
  id           String   @id @default(uuid())
  userId       String
  gymId        String
  cardUid      String // raw UID from reader (uppercase hex, e.g. "A1B2C3D4")
  facilityCode Int? // Wiegand facility code (0-255)
  cardNumber   Int? // Wiegand card number
  cardType     CardType @default(NFC_MIFARE)
  label        String? // "Main fob", "Backup card", "Phone"
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gym          Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, cardUid])
  @@index([gymId, cardUid])
  @@map("card_credentials")
}

model Attendance {
  id       String    @id @default(uuid())
  checkIn  DateTime  @default(now())
  checkOut DateTime?
  duration Int?
  userId   String
  gymId    String
  zoneId   String?
  gym      Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  zone     GymZone?  @relation(fields: [zoneId], references: [id])

  @@index([gymId, checkIn(sort: Desc)])
  @@index([userId, checkIn(sort: Desc)])
  @@index([userId, gymId])
  @@map("attendances")
}

model Notification {
  id          String              @id @default(uuid())
  type        NotificationType
  channel     NotificationChannel
  title       String
  body        String
  data        Json?
  isRead      Boolean             @default(false)
  isSent      Boolean             @default(false)
  sentAt      DateTime?
  scheduledAt DateTime?
  createdAt   DateTime            @default(now())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, type])
  @@index([userId, type, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationPreference {
  id                   String   @id @default(uuid())
  pushEnabled          Boolean  @default(true)
  emailEnabled         Boolean  @default(true)
  smsEnabled           Boolean  @default(false)
  paymentReminders     Boolean  @default(true)
  workoutReminders     Boolean  @default(true)
  mealReminders        Boolean  @default(true)
  waterReminders       Boolean  @default(false)
  motivationalMessages Boolean  @default(true)
  quietHoursEnabled    Boolean  @default(false)
  quietHoursStart      String?
  quietHoursEnd        String?
  fcmToken             String?
  apnsToken            String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Payment {
  id              String        @id @default(uuid())
  amount          Decimal       @db.Decimal(10, 2)
  currency        String        @default("usd")
  status          PaymentStatus @default(PENDING)
  method          PaymentMethod
  description     String?
  stripePaymentId String?       @unique
  stripeInvoiceId String?
  metadata        Json?
  failureReason   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  userId          String
  membershipId    String?
  gymId           String?
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([stripePaymentId])
  @@map("payments")
}

model Deposit {
  id            String        @id @default(uuid())
  amount        Decimal       @db.Decimal(10, 2)
  type          DepositType
  status        DepositStatus @default(PENDING)
  reference     String?
  notes         String?
  currency      String        @default("usd")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  gymId         String
  submittedById String
  approvedById  String?
  approvedBy    User?         @relation("ApprovedDeposits", fields: [approvedById], references: [id])
  gym           Gym           @relation("GymDeposits", fields: [gymId], references: [id], onDelete: Cascade)
  submittedBy   User          @relation("SubmittedDeposits", fields: [submittedById], references: [id])

  @@index([gymId, status])
  @@index([gymId, type])
  @@map("deposits")
}

model PlatformConfig {
  id                String   @id @default("singleton")
  platformName      String   @default("Amirani")
  platformLogoUrl   String?
  supportEmail      String?
  privacyPolicyUrl  String?
  termsOfServiceUrl String?
  maintenanceMode   Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  currency          String   @default("usd")
  defaultTrialDays  Int      @default(14)
  pricePerBranch    Decimal  @default(0.00) @db.Decimal(10, 2)

  @@map("platform_config")
}

model AIConfig {
  id                  String     @id @default("singleton")
  activeProvider      AIProvider @default(OPENAI)
  openaiApiKey        String?
  openaiModel         String     @default("gpt-4-turbo")
  openaiOrgId         String?
  anthropicApiKey     String?
  anthropicModel      String     @default("claude-3-sonnet-20240229")
  googleApiKey        String?
  googleModel         String     @default("gemini-pro")
  azureApiKey         String?
  azureEndpoint       String?
  azureDeploymentName String?
  deepseekApiKey      String?
  deepseekModel       String     @default("deepseek-chat")
  deepseekBaseUrl     String     @default("https://api.deepseek.com")
  maxTokensPerRequest Int        @default(4096)
  temperature         Float      @default(0.7)
  isEnabled           Boolean    @default(true)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@map("ai_config")
}

model PushNotificationConfig {
  id             String   @id @default("singleton")
  fcmEnabled     Boolean  @default(false)
  fcmProjectId   String?
  fcmPrivateKey  String?
  fcmClientEmail String?
  apnsEnabled    Boolean  @default(false)
  apnsKeyId      String?
  apnsTeamId     String?
  apnsPrivateKey String?
  apnsBundleId   String?
  apnsProduction Boolean  @default(false)
  emailEnabled   Boolean  @default(false)
  emailProvider  String?
  sendgridApiKey String?
  smtpHost       String?
  smtpPort       Int?
  smtpUser       String?
  smtpPassword   String?
  fromEmail      String   @default("noreply@amirani.app")
  fromName       String   @default("Amirani")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("push_notification_config")
}

model OAuthConfig {
  id                 String   @id @default("singleton")
  googleEnabled      Boolean  @default(false)
  googleClientId     String?
  googleClientSecret String?
  appleEnabled       Boolean  @default(false)
  appleClientId      String?
  appleTeamId        String?
  appleKeyId         String?
  applePrivateKey    String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("oauth_config")
}

model UserTierLimits {
  id                     String   @id @default(uuid())
  tier                   UserTier @unique
  aiTokensPerMonth       Int      @default(0)
  aiRequestsPerDay       Int      @default(10)
  workoutPlansPerMonth   Int      @default(1)
  dietPlansPerMonth      Int      @default(1)
  canAccessAICoach       Boolean  @default(false)
  canAccessDietPlanner   Boolean  @default(false)
  canAccessAdvancedStats Boolean  @default(false)
  canExportData          Boolean  @default(false)
  maxProgressPhotos      Int      @default(10)
  description            String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("user_tier_limits")
}

model StripeConfig {
  id                 String   @id @default("singleton")
  publishableKey     String?
  secretKey          String?
  webhookSecret      String?
  connectEnabled     Boolean  @default(false)
  platformFeePercent Float    @default(10.0)
  defaultCurrency    String   @default("usd")
  testMode           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("stripe_config")
}

model AIUsageLog {
  id               String     @id @default(uuid())
  userId           String
  provider         AIProvider
  model            String
  promptTokens     Int
  completionTokens Int
  totalTokens      Int
  requestType      String
  cost             Decimal?   @db.Decimal(10, 6)
  createdAt        DateTime   @default(now())

  @@index([userId, createdAt])
  @@map("ai_usage_logs")
}

model WorkoutPlan {
  id            String           @id @default(uuid())
  name          String
  description   String?
  difficulty    DifficultyLevel  @default(BEGINNER)
  isAIGenerated Boolean          @default(false)
  isActive      Boolean          @default(true)
  deletedAt     DateTime?
  status        PlanStatus       @default(DRAFT)
  startDate     DateTime?        @db.Date
  endDate       DateTime?
  numWeeks      Int              @default(1)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  userId        String
  trainerId     String?
  trainer       TrainerProfile?  @relation(fields: [trainerId], references: [id])
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  routines      WorkoutRoutine[]
  versions      WorkoutPlanVersion[]

  // Meta-Coach Infrastructure: Docker-Pattern Pointers
  masterTemplateId String?
  masterTemplate   MasterWorkoutTemplate? @relation(fields: [masterTemplateId], references: [id])
  overrides        PlanDeltaOverride[]

  @@map("workout_plans")
}

// ─── META-COACH DOCKER-PATTERN TEMPLATES ──────────────────────────────────────

model MasterWorkoutTemplate {
  id            String                 @id @default(uuid())
  name          String
  description   String?
  difficulty    DifficultyLevel        @default(BEGINNER)
  isAIGenerated Boolean                @default(false)
  creatorId     String? // Usually a TrainerProfile ID or System
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  routines      MasterWorkoutRoutine[]
  assignedPlans WorkoutPlan[] // "Container Instances"

  @@map("master_workout_templates")
}

model MasterDietTemplate {
  id              String             @id @default(uuid())
  name            String
  targetCalories  Int
  targetProtein   Int
  targetCarbs     Int
  targetFats      Int
  targetWater     Decimal            @default(3.0) @db.Decimal(4, 1)
  isAIGenerated   Boolean            @default(false)
  creatorId       String?            // Trainer or System
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  meals           MasterMeal[]
  assignedPlans   DietPlan[]         @relation("DietContainerInstances")

  @@map("master_diet_templates")
}

model MasterMeal {
  id                String                 @id @default(uuid())
  name              String
  orderIndex        Int                    @default(0)
  /// Explicit day-of-week assignment. When set, the diet hydration uses day-of-week
  /// mapping (matching workout template behaviour) instead of circular index cycling.
  dayOfWeek         DayOfWeek?
  timeOfDay         String?
  instructions      String?
  mediaUrl          String?
  templateId        String
  template          MasterDietTemplate     @relation(fields: [templateId], references: [id], onDelete: Cascade)
  ingredients       MasterMealIngredient[]
  notificationTime  String?
  isReminderEnabled Boolean                @default(true)
  /// P1-D: per-rotation-day macro targets so mobile can show the correct
  /// daily calorie ring for each ABCD day instead of the plan-level average.
  dayTargetCalories Int?
  dayTargetProtein  Int?
  dayTargetCarbs    Int?
  dayTargetFats     Int?
  isLogged          Boolean                @default(false)
  loggedAt          DateTime?

  @@map("master_meals")
}

model MasterMealIngredient {
  id               String               @id @default(uuid())
  name             String
  amount           Decimal              @db.Decimal(8, 2)
  unit             String
  calories         Int
  protein          Decimal              @db.Decimal(8, 2)
  carbs            Decimal              @db.Decimal(8, 2)
  fats             Decimal              @db.Decimal(8, 2)
  mealId           String
